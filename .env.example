# infra
# Host ports match docker-compose.yml (remapped from the 5432/6379 defaults —
# see the comment there). If your machine doesn't have the same port-blocking
# issue, feel free to change both back to 5432/6379 in both files.
DATABASE_URL=postgresql+asyncpg://apibuilder:apibuilder@localhost:25432/apibuilder
REDIS_URL=redis://localhost:25379/0

# auth (google oauth)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=changeme
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
FRONTEND_ORIGIN=http://localhost:3000
SESSION_SECRET=changeme-random-32-bytes
ADMIN_EMAILS=you@example.com

# security
AUTH_STATE_FERNET_KEY=changeme-generate-with-Fernet.generate_key()

# billing (bkash)
BKASH_RECEIVE_MSISDN=01XXXXXXXXX
SMS_WEBHOOK_TOKEN=changeme-random
PLAN_PRICE_PRO_BDT=100
PLAN_PRICE_MAX_BDT=500
QUOTA_TZ=Asia/Dhaka
PAYMENT_INTENT_TTL_HOURS=24

# llm
LLAMA_BASE_URL=http://127.0.0.1:8080/v1
LLM_ENABLED=true

# worker
REC_MAX_CONCURRENCY=1
EXEC_MAX_CONCURRENCY=2
EXEC_TIMEOUT_SECONDS=90
SYNC_WAIT_SECONDS=55
PROFILES_DIR=./data/profiles
FAILURES_DIR=./data/failures
